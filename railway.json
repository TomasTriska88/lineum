{
  "$schema": "https://railway.app/v2.schema.json",
  "services": {
    "portal": {
      "source": {
        "rootDirectory": "./"
      },
      "build": {
        "buildCommand": "npm --prefix portal install && npm --prefix portal run build",
        "watchPatterns": [
          "portal/**",
          "whitepapers/**",
          "source/**"
        ]
      },
      "deploy": {
        "startCommand": "npm --prefix portal start",
        "healthCheckPath": "/wiki/lineum-core"
      }
    },
    "lab": {
      "source": {
        "rootDirectory": "lab"
      }
    }
  }
}