{
  "$schema": "https://railway.app/v2.schema.json",
  "services": {
    "Portal": {
      "source": {
        "rootDirectory": "./"
      },
      "build": {
        "buildCommand": "echo '--- BUILDING PORTAL ---' && ls -la && cd portal && npm install && npm run build && echo '--- POST-BUILD CHECK ---' && ls -la src/lib/data/whitepapers || echo 'No whitepapers in build directory'",
        "watchPatterns": [
          "portal/**",
          "whitepapers/**",
          "source/**"
        ]
      },
      "deploy": {
        "startCommand": "cd portal && node build",
        "healthCheckPath": "/wiki/lineum-core",
        "restartPolicyType": "ON_FAILURE"
      }
    },
    "portal": {
      "source": {
        "rootDirectory": "./"
      },
      "build": {
        "buildCommand": "echo '--- BUILDING PORTAL ---' && ls -la && cd portal && npm install && npm run build && echo '--- POST-BUILD CHECK ---' && ls -la src/lib/data/whitepapers || echo 'No whitepapers in build directory'",
        "watchPatterns": [
          "portal/**",
          "whitepapers/**",
          "source/**"
        ]
      },
      "deploy": {
        "startCommand": "cd portal && node build",
        "healthCheckPath": "/wiki/lineum-core",
        "restartPolicyType": "ON_FAILURE"
      }
    },
    "Simulacrum": {
      "source": {
        "rootDirectory": "lab"
      },
      "build": {
        "buildCommand": "cd lab && npm install && npm run build",
        "watchPatterns": [
          "lab/**"
        ]
      },
      "deploy": {
        "startCommand": "cd lab && npm run preview -- --host --port $PORT"
      }
    }
  }
}