{
	"name": "portal",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"start": "node build",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"check:i18n": "node scripts/check-czech.js",
		"test": "vitest run",
		"test:e2e": "playwright test",
		"sync": "node scripts/sync-data.js",
		"prebuild": "npm run sync"
	},
	"devDependencies": {
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-node": "^5.2.11",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/node": "^25.2.3",
		"jsdom": "^28.1.0",
		"mdsvex": "^0.12.6",
		"svelte": "^5.49.2",
		"svelte-check": "^4.3.6",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"@google/generative-ai": "^0.24.1",
		"@types/uuid": "^10.0.0",
		"dotenv": "^17.3.1",
		"marked": "^17.0.2",
		"node-fetch": "^3.3.2",
		"uuid": "^13.0.0"
	}
}