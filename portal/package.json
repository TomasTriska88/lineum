{
	"name": "portal",
	"private": true,
	"version": "2026.02.28-1148",
	"type": "module",
	"scripts": {
		"predev": "npx -y kill-port 5173 5174 8000 || exit 0",
		"dev": "npm run sync && npx -y concurrently -k -c \"blue,green,magenta\" -n \"portal,lab,api\" \"npm run dev:portal\" \"npm run dev:lab\" \"npm run dev:api\"",
		"dev:portal": "vite dev --host 127.0.0.1 --port 5173 --strictPort",
		"dev:lab": "cd ../lab && npm run dev",
		"dev:api": "cd ../routing_backend && uvicorn main:app --reload --host 127.0.0.1 --port 8000",
		"build": "node scripts/railway-build.cjs",
		"preview": "vite preview",
		"start": "node build",
		"prepare": "git config core.hooksPath ../.githooks && svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"check:i18n": "node scripts/check-czech.js",
		"check:licenses": "node scripts/check-licenses.js",
		"test": "vitest run",
		"test:e2e": "playwright test",
		"sync": "node scripts/sync-data.js",
		"stage": "node scripts/stage-railway.js",
		"prebuild": "npm run sync",
		"safe-merge": "node scripts/safe-merge.cjs"
	},
	"devDependencies": {
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-node": "^5.2.11",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/node": "^25.2.3",
		"autoprefixer": "^10.4.24",
		"cross-env": "^10.1.0",
		"jsdom": "^28.1.0",
		"license-checker-rseidelsohn": "^4.4.2",
		"mdsvex": "^0.12.6",
		"postcss": "^8.5.6",
		"svelte": "^5.49.2",
		"svelte-check": "^4.3.6",
		"tailwindcss": "^4.2.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"@google/generative-ai": "^0.24.1",
		"@inlang/paraglide-js": "1.11.8",
		"@inlang/paraglide-sveltekit": "^0.16.1",
		"@tailwindcss/postcss": "^4.2.0",
		"@types/uuid": "^10.0.0",
		"canvas": "^3.2.1",
		"dotenv": "^17.3.1",
		"katex": "^0.16.28",
		"marked": "^17.0.2",
		"marked-katex-extension": "^5.1.7",
		"node-fetch": "^3.3.2",
		"uuid": "^13.0.0"
	}
}
